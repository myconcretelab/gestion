{
  "name": "contrats-monorepo",
  "private": true,
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "deploy": "bash ./bin/deploy",
    "build": "npm run build -w client && npm run build -w server",
    "test": "npm run test -w server && npm run test -w client",
    "start": "npm run start -w server",
    "migrate": "npm run migrate -w server",
    "update": "bash ./update",
    "seed": "npm run seed -w server",
    "dev:db": "npm run dev:db -w server",
    "dev:reset": "npm run dev:reset -w server",
    "prod:migrate": "npm run prod:migrate -w server",
    "prod:generate": "npm run prod:generate -w server",
    "cron:ical": "npm run cron:ical -w server",
    "db:studio": "npm run db:studio -w server",
    "prisma:generate": "npm run prisma:generate -w server",
    "prisma:use:sqlite": "npm run prisma:use:sqlite -w server",
    "prisma:use:postgres": "npm run prisma:use:postgres -w server",
    "db:migrate:sqlite-to-postgres": "npm run db:migrate:sqlite-to-postgres -w server"
  },
  "overrides": {
    "body-parser": {
      "qs": "^6.15.1"
    },
    "c12": {
      "defu": "^6.1.7"
    },
    "concurrently": {
      "lodash": "^4.18.1"
    },
    "express": {
      "path-to-regexp": "0.1.13",
      "qs": "^6.15.1"
    },
    "vite": {
      "rollup": "^4.60.1"
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
