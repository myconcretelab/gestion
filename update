#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

LIGHT_MODE=0

usage() {
  cat <<'EOF'
Usage:
  ./update
  ./update -light
  ./update --light
  ./update --help

Options:
  -light, --light  Deploiement rapide: sans reinstall des dependances, sans tests ni migrations
  --help, -h       Affiche cette aide
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -light|--light)
      LIGHT_MODE=1
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Option inconnue: $1"
      usage
      exit 1
      ;;
  esac
done

load_env_file() {
  local file="$1"
  if [[ -f "$file" ]]; then
    local label="${file#$ROOT_DIR/}"
    echo "==> Load env from ${label}"
    set -a
    # shellcheck disable=SC1090
    source "$file"
    set +a
  fi
}

# Allow restart settings to live in env files, with later files overriding earlier ones.
load_env_file "$ROOT_DIR/.env"
load_env_file "$ROOT_DIR/.env.production"
load_env_file "$ROOT_DIR/.env.update"

format_elapsed() {
  local total_seconds="$1"
  local minutes=$((total_seconds / 60))
  local seconds=$((total_seconds % 60))
  printf "%dm%02ds" "$minutes" "$seconds"
}

run_step() {
  local label="$1"
  shift

  local started_at ended_at
  started_at=$(date +%s)
  echo "==> ${label}"

  "$@"

  ended_at=$(date +%s)
  echo "==> ${label} done in $(format_elapsed $((ended_at - started_at)))"
}

resolve_playwright_browsers_path() {
  local value="$1"
  if [[ "$value" == "0" ]]; then
    echo "0"
    return
  fi
  if [[ "$value" == "~" ]]; then
    value="$HOME"
  elif [[ "$value" == "~/"* ]]; then
    value="$HOME/${value#~/}"
  fi
  if [[ "$value" != /* ]]; then
    value="$ROOT_DIR/$value"
  fi
  echo "$value"
}

has_local_changes() {
  if ! git diff --quiet; then
    return 0
  fi
  if ! git diff --cached --quiet; then
    return 0
  fi
  if [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
    return 0
  fi
  return 1
}

reset_generated_prisma_schema() {
  local schema_path="server/prisma/postgres/schema.prisma"
  if ! git ls-files --error-unmatch "$schema_path" >/dev/null 2>&1; then
    return
  fi
  if ! git diff --quiet -- "$schema_path" || ! git diff --cached --quiet -- "$schema_path"; then
    echo "==> Reset generated Prisma schema (${schema_path})"
    git restore --staged --worktree -- "$schema_path"
  fi
}

restart_server() {
  if [[ "${SKIP_RESTART:-0}" == "1" ]]; then
    echo "==> Skip restart (SKIP_RESTART=1)"
    return
  fi

  if [[ -n "${RESTART_CMD:-}" ]]; then
    run_step "Restart server with RESTART_CMD" bash -lc "${RESTART_CMD}"
    return
  fi

  if [[ -n "${ALWAYSDATA_API_TOKEN:-}" && -n "${ALWAYSDATA_ACCOUNT:-}" && -n "${ALWAYSDATA_SITE_ID:-}" ]]; then
    if ! command -v curl >/dev/null 2>&1; then
      echo "curl is required for Alwaysdata API restart."
      exit 1
    fi

    run_step \
      "Restart Alwaysdata site ${ALWAYSDATA_SITE_ID}" \
      curl --fail --silent --show-error \
        -X POST \
        --basic \
        --user "${ALWAYSDATA_API_TOKEN} account=${ALWAYSDATA_ACCOUNT}:" \
        "https://api.alwaysdata.com/v1/site/${ALWAYSDATA_SITE_ID}/restart/"
    return
  fi

  local missing_alwaysdata_vars=()
  [[ -z "${ALWAYSDATA_API_TOKEN:-}" ]] && missing_alwaysdata_vars+=("ALWAYSDATA_API_TOKEN")
  [[ -z "${ALWAYSDATA_ACCOUNT:-}" ]] && missing_alwaysdata_vars+=("ALWAYSDATA_ACCOUNT")
  [[ -z "${ALWAYSDATA_SITE_ID:-}" ]] && missing_alwaysdata_vars+=("ALWAYSDATA_SITE_ID")

  if [[ ${#missing_alwaysdata_vars[@]} -lt 3 ]]; then
    echo "==> No restart configured."
    echo "==> Missing Alwaysdata restart vars: ${missing_alwaysdata_vars[*]}"
    echo "==> Set RESTART_CMD, or define ALWAYSDATA_API_TOKEN, ALWAYSDATA_ACCOUNT, and ALWAYSDATA_SITE_ID in env or .env.update."
    return
  fi

  echo "==> No restart configured (set RESTART_CMD or ALWAYSDATA_API_TOKEN/ALWAYSDATA_ACCOUNT/ALWAYSDATA_SITE_ID in env or .env.update)."
}

reset_generated_prisma_schema

STASH_CREATED=0
if has_local_changes; then
  STASH_CREATED=1
  STASH_MESSAGE="update-auto-stash-$(date +%Y%m%d-%H%M%S)"
  echo "==> Local changes detected, stash before pull"
  git stash push --include-untracked -m "$STASH_MESSAGE" >/dev/null
fi

run_step "Pull latest code" git pull

if [[ "$STASH_CREATED" == "1" ]]; then
  echo "==> Reapply stashed changes"
  if ! git stash pop --index; then
    echo "==> Warning: stash could not be fully reapplied automatically. Resolve conflicts, then run 'git stash list' if needed."
    exit 1
  fi
fi

if [[ "$LIGHT_MODE" == "1" ]]; then
  echo "==> Light mode: skip dependency reinstall"
else
  NPM_INSTALL_MODE="${NPM_INSTALL_MODE:-ci}"

  case "$NPM_INSTALL_MODE" in
    ci)
      run_step "Install/update dependencies with npm ci" npm ci --include=optional
      ;;
    install)
      run_step "Install/update dependencies with npm install (keeps existing node_modules)" npm install --include=optional
      ;;
    *)
      echo "Invalid NPM_INSTALL_MODE='${NPM_INSTALL_MODE}'. Expected 'ci' or 'install'."
      exit 1
      ;;
  esac
fi

if [[ "$LIGHT_MODE" == "1" ]]; then
  echo "==> Light mode: skip Playwright install, Prisma prod generate, tests, and prod migrations"
else
  PLAYWRIGHT_BROWSERS_PATH_VALUE_RAW="${PLAYWRIGHT_BROWSERS_PATH:-$ROOT_DIR/.cache/ms-playwright}"
  PLAYWRIGHT_BROWSERS_PATH_VALUE="$(resolve_playwright_browsers_path "$PLAYWRIGHT_BROWSERS_PATH_VALUE_RAW")"
  if [[ "$PLAYWRIGHT_BROWSERS_PATH_VALUE_RAW" != "$PLAYWRIGHT_BROWSERS_PATH_VALUE" ]]; then
    echo "==> Normalized PLAYWRIGHT_BROWSERS_PATH: ${PLAYWRIGHT_BROWSERS_PATH_VALUE_RAW} -> ${PLAYWRIGHT_BROWSERS_PATH_VALUE}"
  fi

  if [[ "${SKIP_PLAYWRIGHT_INSTALL:-0}" != "1" ]]; then
    echo "==> Ensure Playwright Chromium is installed (PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH_VALUE})"
    if [[ "${PLAYWRIGHT_BROWSERS_PATH_VALUE}" != "0" ]]; then
      mkdir -p "${PLAYWRIGHT_BROWSERS_PATH_VALUE}"
    else
      echo "==> Warning: PLAYWRIGHT_BROWSERS_PATH=0 stores browsers inside node_modules."
      echo "==>          With npm ci, browsers are removed and must be reinstalled each deploy."
    fi
    run_step \
      "Install Playwright Chromium" \
      env PLAYWRIGHT_BROWSERS_PATH="${PLAYWRIGHT_BROWSERS_PATH_VALUE}" npm exec --workspace=server playwright install chromium
  else
    echo "==> Skip Playwright install (SKIP_PLAYWRIGHT_INSTALL=1)"
  fi

  run_step "Generate Prisma client (PostgreSQL)" npm run prod:generate

  if [[ "${SKIP_TESTS:-0}" != "1" ]]; then
    run_step "Run tests" npm run test
  else
    echo "==> Skip tests (SKIP_TESTS=1)"
  fi
fi

if [[ "${SKIP_BUILD:-0}" != "1" ]]; then
  run_step "Build client + server" npm run build
else
  echo "==> Skip build (SKIP_BUILD=1)"
fi

if [[ "$LIGHT_MODE" == "1" ]]; then
  echo "==> Light mode: skip PostgreSQL migrations"
else
  run_step "Apply database migrations (PostgreSQL)" npm run prod:migrate
fi

restart_server

echo "==> Update complete"
