generator client {
  provider = "prisma-client-js"
}

generator sqlite_client {
  provider = "prisma-client-js"
  output   = "../generated/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Gite {
  id                                   String   @id @default(cuid())
  ordre                                Int      @default(0)
  nom                                  String
  prefixe_contrat                      String
  adresse_ligne1                       String
  adresse_ligne2                       String?
  capacite_max                         Int
  nb_adultes_max                       Int      @default(1)
  nb_adultes_habituel                  Int      @default(1)
  nb_enfants_max                       Int      @default(0)
  proprietaires_noms                   String
  proprietaires_adresse                String
  site_web                             String?
  public_slug                          String?
  public_title                         String?
  public_summary                       String?
  public_description                   String?
  public_technical_description         String?
  public_seo_title                     String?
  public_seo_description               String?
  public_is_published                  Boolean  @default(false)
  public_structured_content            String?
  public_equipment                     String?
  public_rooms                         String?
  public_practical_info                String?
  public_location_info                 String?
  public_web_info                      String?
  public_latitude                      Float?
  public_longitude                     Float?
  email                                String?
  telephones                           String
  taxe_sejour_par_personne_par_nuit    Float
  iban                                 String
  bic                                  String?
  titulaire                            String
  regle_animaux_acceptes               Boolean  @default(false)
  regle_bois_premiere_flambee          Boolean  @default(false)
  regle_tiers_personnes_info           Boolean  @default(false)
  options_draps_par_lit                Float  @default(0)
  options_linge_toilette_par_personne  Float  @default(0)
  options_menage_forfait               Float  @default(0)
  options_depart_tardif_forfait        Float  @default(0)
  options_chiens_forfait               Float  @default(0)
  heure_arrivee_defaut                 String  @default("17:00")
  heure_depart_defaut                  String  @default("12:00")
  caution_montant_defaut               Float  @default(0)
  cheque_menage_montant_defaut         Float  @default(0)
  arrhes_taux_defaut                   Float  @default(0.2)
  electricity_price_per_kwh            Float  @default(0)
  frais_gestion                        String?
  prix_nuit_basse_saison               Float  @default(0)
  prix_nuit_haute_saison               Float  @default(0)
  min_nuits_toute_annee                Int    @default(1)
  min_nuits_vacances_scolaires         Int    @default(1)
  min_nuits_juillet_aout               Int    @default(1)
  prix_nuit_liste                      String?
  caracteristiques                     String?
  airbnb_listing_id                    String?
  ical_export_token                    String?
  gestionnaire_id                      String?
  date_debut_activite                  DateTime?
  createdAt                            DateTime @default(now())
  updatedAt                            DateTime @updatedAt

  gestionnaire                         Gestionnaire? @relation(fields: [gestionnaire_id], references: [id], onDelete: SetNull)
  ical_sources                         IcalSource[]
  contrats                             Contrat[]
  factures                             Facture[]
  reservations                         Reservation[]
  guest_night_declarations             GuestNightDeclaration[]
  monthly_energy_readings              GiteMonthlyEnergyReading[]
  season_rates                         GiteSeasonRate[]
  booking_requests                     BookingRequest[]
  photos                               GitePhoto[]
  wordpress_photo_sync_job             WordPressWebhookJob?
  counters                             ContratCounter[]
  facture_counters                     FactureCounter[]

  @@unique([public_slug], map: "gites_public_slug_key")
  @@index([gestionnaire_id], map: "gites_gestionnaire_id_idx")
  @@index([ical_export_token], map: "gites_ical_export_token_idx")
  @@index([ordre], map: "gites_ordre_idx")
  @@index([public_is_published, ordre], map: "gites_public_published_ordre_idx")
  @@map("gites")
}

model GitePhoto {
  id          String   @id @default(cuid())
  gite_id     String
  url         String
  title       String?
  alt         String?
  credit      String?
  is_primary  Boolean  @default(false)
  is_public   Boolean  @default(true)
  ordre       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gite        Gite     @relation(fields: [gite_id], references: [id], onDelete: Cascade)

  @@index([gite_id, ordre], map: "gite_photos_gite_ordre_idx")
  @@index([gite_id, is_public, ordre], map: "gite_photos_public_ordre_idx")
  @@map("gite_photos")
}

model WordPressWebhookJob {
  id              String    @id @default(cuid())
  gite_id         String    @unique
  event           String    @default("gite.photos.saved")
  state           String    @default("queued")
  generation      Int       @default(0)
  attempts        Int       @default(0)
  max_attempts    Int       @default(3)
  run_after       DateTime
  queued_at       DateTime  @default(now())
  sent_at         DateTime?
  completed_at    DateTime?
  response_status Int?
  response_body   String?
  last_error      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  gite            Gite      @relation(fields: [gite_id], references: [id], onDelete: Cascade)

  @@index([state, run_after], map: "wordpress_webhook_jobs_state_run_after_idx")
  @@map("wordpress_webhook_jobs")
}

model Gestionnaire {
  id        String   @id @default(cuid())
  prenom    String
  nom       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gites               Gite[]
  urssaf_declarations UrssafDeclaration[]

  @@unique([prenom, nom])
  @@map("gestionnaires")
}

model UrssafDeclaration {
  id             String       @id @default(cuid())
  year           Int
  month          Int
  gestionnaire_id String
  amount         Float        @default(0)
  declared_at    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  gestionnaire   Gestionnaire @relation(fields: [gestionnaire_id], references: [id], onDelete: Cascade)

  @@unique([year, month, gestionnaire_id], map: "urssaf_declarations_period_manager_key")
  @@index([year, month], map: "urssaf_declarations_period_idx")
  @@index([gestionnaire_id], map: "urssaf_declarations_manager_idx")
  @@map("urssaf_declarations")
}

model GuestNightDeclaration {
  id           String   @id @default(cuid())
  year         Int
  month        Int
  gite_id      String
  guest_nights Int      @default(0)
  declared_at  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gite         Gite     @relation(fields: [gite_id], references: [id], onDelete: Cascade)

  @@unique([year, month, gite_id], map: "guest_night_declarations_period_gite_key")
  @@index([year, month], map: "guest_night_declarations_period_idx")
  @@index([gite_id], map: "guest_night_declarations_gite_idx")
  @@map("guest_night_declarations")
}

model IcalSource {
  id              String   @id @default(cuid())
  gite_id         String
  type            String
  url             String
  include_summary String?
  exclude_summary String?
  is_active       Boolean  @default(true)
  ordre           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gite            Gite     @relation(fields: [gite_id], references: [id], onDelete: Cascade)

  @@unique([gite_id, url], map: "ical_sources_gite_url_key")
  @@index([gite_id, ordre], map: "ical_sources_gite_id_ordre_idx")
  @@index([is_active], map: "ical_sources_is_active_idx")
  @@map("ical_sources")
}

model Contrat {
  id                     String   @id @default(cuid())
  numero_contrat         String   @unique
  gite_id                String
  date_creation          DateTime @default(now())
  date_derniere_modif    DateTime @updatedAt
  locataire_nom          String
  locataire_adresse      String
  locataire_tel          String
  locataire_email        String?
  nb_adultes             Int
  nb_enfants_2_17        Int
  date_debut             DateTime
  heure_arrivee          String
  date_fin               DateTime
  heure_depart           String
  nb_nuits               Int
  prix_par_nuit          Float
  remise_montant         Float @default(0)
  taxe_sejour_calculee   Float? 
  options                String
  arrhes_montant         Float
  arrhes_date_limite     DateTime
  solde_montant          Float
  caution_montant        Float
  cheque_menage_montant  Float
  afficher_caution_phrase Boolean @default(true)
  afficher_cheque_menage_phrase Boolean @default(true)
  clauses                String
  pdf_path               String
  pdf_sent_path          String?
  signed_document_path   String?
  signed_document_filename String?
  signed_document_mime_type String?
  signed_document_size   Int?
  signed_document_uploaded_at DateTime?
  snapshot_json          String?
  date_envoi_email       DateTime?
  statut_reception_contrat String   @default("non_recu")
  date_reception_contrat DateTime?
  statut_paiement_arrhes String   @default("non_recu")
  date_paiement_arrhes   DateTime?
  statut_paiement_solde  String   @default("non_regle")
  mode_paiement_arrhes   String?
  notes                  String?
  commentaire_interne    String?
  reservation_id         String?

  gite                   Gite     @relation(fields: [gite_id], references: [id])

  @@index([reservation_id], map: "contrats_reservation_id_idx")
  @@map("contrats")
}

model ContratCounter {
  id        String @id @default(cuid())
  giteId    String
  year      Int
  lastNumber Int

  gite      Gite   @relation(fields: [giteId], references: [id])

  @@unique([giteId, year])
  @@map("contrat_counters")
}

model Facture {
  id                     String   @id @default(cuid())
  numero_facture         String   @unique
  gite_id                String
  date_creation          DateTime @default(now())
  date_derniere_modif    DateTime @updatedAt
  locataire_nom          String
  locataire_adresse      String
  locataire_tel          String
  locataire_email        String?
  nb_adultes             Int
  nb_enfants_2_17        Int
  date_debut             DateTime
  heure_arrivee          String
  date_fin               DateTime
  heure_depart           String
  nb_nuits               Int
  prix_par_nuit          Float
  remise_montant         Float @default(0)
  frais_supplementaires  String @default("[]")
  taxe_sejour_calculee   Float?
  options                String
  arrhes_montant         Float
  arrhes_date_limite     DateTime
  solde_montant          Float
  caution_montant        Float
  cheque_menage_montant  Float
  afficher_caution_phrase Boolean @default(true)
  afficher_cheque_menage_phrase Boolean @default(true)
  clauses                String
  pdf_path               String
  date_envoi_email       DateTime?
  statut_paiement        String   @default("non_reglee")
  notes                  String?
  reservation_id         String?

  gite                   Gite     @relation(fields: [gite_id], references: [id])

  @@index([reservation_id], map: "factures_reservation_id_idx")
  @@map("factures")
}

model FactureCounter {
  id         String @id @default(cuid())
  giteId     String
  year       Int
  lastNumber Int

  gite       Gite   @relation(fields: [giteId], references: [id])

  @@unique([giteId, year])
  @@map("facture_counters")
}

model ReservationPlaceholder {
  id           String        @id @default(cuid())
  abbreviation String        @unique
  label        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  reservations Reservation[]

  @@map("reservation_placeholders")
}

model PlanningRelayPeriod {
  id               String    @id @default(cuid())
  label            String
  date_debut       DateTime
  date_fin         DateTime
  gite_ids         String    @default("[]")
  show_timeline    Boolean   @default(false)
  show_comments    Boolean   @default(false)
  show_phones      Boolean   @default(false)
  stay_nights      Int?
  is_active        Boolean   @default(true)
  share_nonce      String
  public_code_hash String?   @unique
  expires_at       DateTime?
  last_accessed_at DateTime?
  sms_enabled      Boolean   @default(false)
  sms_recipient    String?
  sms_worker_id    String?
  sms_send_time    String    @default("18:00")
  sms_send_day     String    @default("previous_day")
  sms_last_sent_for_date    String?
  sms_last_attempt_for_date String?
  sms_configs      String    @default("[]")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  assignments      PlanningRelayAssignment[]
  sms_worker       PlanningRelayWorker? @relation("PlanningRelayPeriodSmsWorker", fields: [sms_worker_id], references: [id], onDelete: SetNull)

  @@index([is_active, date_fin], map: "planning_relay_periods_active_date_fin_idx")
  @@index([sms_enabled, sms_send_time], map: "planning_relay_periods_sms_schedule_idx")
  @@index([sms_worker_id], map: "planning_relay_periods_sms_worker_idx")
  @@map("planning_relay_periods")
}

model PlanningRelayWorker {
  id          String   @id @default(cuid())
  nom         String
  telephone   String
  email       String?
  adresse     String?
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments PlanningRelayAssignment[]
  sms_periods PlanningRelayPeriod[] @relation("PlanningRelayPeriodSmsWorker")

  @@index([is_active, nom], map: "planning_relay_workers_active_nom_idx")
  @@map("planning_relay_workers")
}

model PlanningRelayAssignment {
  id         String   @id @default(cuid())
  period_id String
  date      String
  gite_id   String
  worker_id String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  period     PlanningRelayPeriod @relation(fields: [period_id], references: [id], onDelete: Cascade)
  worker     PlanningRelayWorker @relation(fields: [worker_id], references: [id], onDelete: Cascade)

  @@unique([period_id, date, gite_id], map: "planning_relay_assignments_period_date_gite_key")
  @@index([worker_id], map: "planning_relay_assignments_worker_idx")
  @@map("planning_relay_assignments")
}

model SecurityThrottle {
  key               String    @id
  scope             String
  failure_count     Int       @default(0)
  window_started_at DateTime
  blocked_until     DateTime?
  updatedAt         DateTime  @updatedAt

  @@index([scope, updatedAt], map: "security_throttles_scope_updated_at_idx")
  @@map("security_throttles")
}

model Reservation {
  id                       String                  @id @default(cuid())
  gite_id                  String?
  stay_group_id            String?
  placeholder_id           String?
  origin_system            String?
  origin_reference         String?
  export_to_ical           Boolean?
  airbnb_url               String?
  hote_nom                 String
  telephone                String?
  email                    String?
  date_entree              DateTime
  date_sortie              DateTime
  nb_nuits                 Int
  nb_adultes               Int
  nb_enfants_2_17          Int                     @default(0)
  prix_par_nuit            Float
  prix_total               Float
  source_paiement          String?
  commentaire              String?
  remise_montant           Float                  @default(0)
  commission_channel_mode  String?                @default("euro")
  commission_channel_value Float                  @default(0)
  frais_optionnels_montant Float                  @default(0)
  frais_optionnels_libelle String?
  frais_optionnels_declares Boolean               @default(false)
  options                  String                 @default("{}")
  energy_consumption_kwh   Float                  @default(0)
  energy_cost_eur          Float                  @default(0)
  energy_price_per_kwh     Float?
  energy_tracking          String                 @default("[]")
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  gite                     Gite?                  @relation(fields: [gite_id], references: [id])
  placeholder              ReservationPlaceholder? @relation(fields: [placeholder_id], references: [id])
  approved_booking_requests BookingRequest[]      @relation("ApprovedBookingRequest")

  @@index([gite_id, date_entree])
  @@index([gite_id, date_sortie], map: "reservations_gite_id_date_sortie_idx")
  @@index([gite_id, export_to_ical, date_entree], map: "reservations_gite_export_to_ical_date_entree_idx")
  @@index([date_entree, createdAt], map: "reservations_date_entree_createdAt_idx")
  @@index([date_sortie], map: "reservations_date_sortie_idx")
  @@index([createdAt, date_entree], map: "reservations_createdAt_date_entree_idx")
  @@index([updatedAt, createdAt], map: "reservations_updatedAt_createdAt_idx")
  @@index([origin_system, origin_reference], map: "reservations_origin_system_origin_reference_idx")
  @@index([origin_system, createdAt], map: "reservations_origin_system_createdAt_idx")
  @@index([placeholder_id, date_entree])
  @@index([placeholder_id, date_sortie], map: "reservations_placeholder_id_date_sortie_idx")
  @@index([stay_group_id], map: "reservations_stay_group_id_idx")
  @@map("reservations")
}

model GiteSeasonRate {
  id            String   @id @default(cuid())
  gite_id       String
  date_debut    DateTime
  date_fin      DateTime
  prix_par_nuit Float
  min_nuits     Int      @default(1)
  ordre         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gite          Gite     @relation(fields: [gite_id], references: [id], onDelete: Cascade)

  @@index([gite_id, ordre], map: "gite_season_rates_gite_id_ordre_idx")
  @@index([gite_id, date_debut, date_fin], map: "gite_season_rates_gite_dates_idx")
  @@map("gite_season_rates")
}

model BookingRequest {
  id                     String       @id @default(cuid())
  gite_id                String
  approved_reservation_id String?
  hote_nom               String
  telephone              String?
  email                  String?
  date_entree            DateTime
  date_sortie            DateTime
  nb_nuits               Int
  nb_adultes             Int
  nb_enfants_2_17        Int          @default(0)
  options                String       @default("{}")
  message_client         String?
  pricing_snapshot       String
  status                 String       @default("pending")
  hold_expires_at        DateTime
  decided_at             DateTime?
  decision_note          String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  gite                   Gite         @relation(fields: [gite_id], references: [id], onDelete: Cascade)
  approved_reservation   Reservation? @relation("ApprovedBookingRequest", fields: [approved_reservation_id], references: [id], onDelete: SetNull)

  @@index([gite_id, status, hold_expires_at], map: "booking_requests_gite_status_hold_idx")
  @@index([gite_id, date_entree, date_sortie], map: "booking_requests_gite_dates_idx")
  @@index([approved_reservation_id], map: "booking_requests_approved_reservation_idx")
  @@map("booking_requests")
}

model GiteMonthlyEnergyReading {
  id                 String   @id @default(cuid())
  gite_id            String
  year               Int
  month              Int
  device_id          String
  device_name        String
  opening_total_kwh  Float?
  opening_recorded_at DateTime?
  closing_total_kwh  Float?
  closing_recorded_at DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  gite               Gite     @relation(fields: [gite_id], references: [id], onDelete: Cascade)

  @@unique([gite_id, year, month, device_id], map: "gite_monthly_energy_readings_period_device_key")
  @@index([year, month], map: "gite_monthly_energy_readings_period_idx")
  @@index([gite_id, year, month], map: "gite_monthly_energy_readings_gite_period_idx")
  @@map("gite_monthly_energy_readings")
}
