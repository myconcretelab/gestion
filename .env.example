# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# Optional bootstrap password used only to initialize the hashed server auth on first start.
BASIC_AUTH_PASSWORD=
# Optional: bearer token for machine-to-machine integrations (ex: what-today)
INTEGRATION_API_TOKEN=
PUMP_API_BASE_URL=http://localhost:3000/api/reservations
PUMP_API_KEY=
PUMP_BASE_URL=https://www.airbnb.fr/hosting/multicalendar
PUMP_USERNAME=
PUMP_SESSION_PASSWORD=
PUMP_AUTH_MODE=persisted-only
PUMP_HAS_OTP=false
PUMP_PERSIST_SESSION=true
PUMP_MANUAL_SCROLL_MODE=false
PUMP_MANUAL_SCROLL_DURATION=20000
PUMP_SCROLL_SELECTOR=
PUMP_SCROLL_COUNT=5
PUMP_SCROLL_DISTANCE=500
PUMP_SCROLL_DELAY=1000
PUMP_WAIT_BEFORE_SCROLL=2000
PUMP_OUTPUT_FOLDER=
PUMP_HEALTH_STALE_AFTER_HOURS=96
PUMP_LOGIN_STRATEGY=simple
PUMP_IMPORT_CRON_ENABLED=true
PUMP_IMPORT_CRON_SCHEDULER=internal
PUMP_IMPORT_CRON_RUN_ON_START=false
PUMP_IMPORT_CRON_INTERVAL_DAYS=3
PUMP_IMPORT_CRON_HOUR=10
PUMP_IMPORT_CRON_MINUTE=0
PUMP_ALERT_EMAIL_ENABLED=true
PUMP_ALERT_EMAIL_TO=
PUMP_ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_REPLY_TO=
DEFAULT_ARRHES_RATE=0.2
DATA_DIR=./data
PDF_SUBDIR=pdfs
ICAL_SYNC_ENABLED=true
CRON_TRIGGER_TOKEN=

# Prisma (SQLite local)
DATABASE_URL="file:./server/prisma/dev.db"

# Optional in production
# CLIENT_DIST_DIR=/home/USER/app/client/dist
# PLAYWRIGHT_BROWSERS_PATH=/home/USER/.cache/ms-playwright
